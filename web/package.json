    "eslint-plugin-compat": "^6.0.2",
    "eslint-plugin-vue": "^10.4.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "prettier": "3.3.2",
    "pretty-quick": "^4.2.2",
    "sonda": "^0.7.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "unplugin-auto-import": "^0.17.8",
