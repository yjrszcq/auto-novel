  "type": "module",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Edge versions",
    "last 2 Firefox versions",
    "last 2 Safari versions"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --noEmit",
    "lint": "eslint src tests e2e scripts --max-warnings 0",
